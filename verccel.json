{
  "installCommand": "pnpm install",
  "buildCommand": "pnpm --filter @workspace/library-app run build",
  "outputDirectory": "artifacts/library-app/dist/public",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" }
  ],
  "functions": {
    "api/index.ts": {
      "runtime": "@vercel/node@4"
    }
  }
}
